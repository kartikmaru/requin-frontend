# ─────────────────────────────────────────────────────
# CLIENT environment variables (Vite project)
# Copy this file to .env and fill in real values.
# NEVER put secrets (DB passwords, JWT_SECRET, etc.) here —
# Vite bakes ALL VITE_ variables into the browser bundle.
# ─────────────────────────────────────────────────────

# Backend API base URL
# Local dev: leave empty — Vite proxy handles /api/* → localhost:5000
# Production (Render/Railway): https://your-api.onrender.com
VITE_API_BASE_URL=
